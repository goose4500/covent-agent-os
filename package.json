{
  "name": "covent-agent-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private Covent AI automation operating layer for Slack, Pi, skills, agents, and bounded tools.",
  "workspaces": [
    "apps/pi-mom",
    "packages/*"
  ],
  "scripts": {
    "check": "bun run secret-scan && bun run validate:skills && bun run validate:agents && bun run check:pi-mom && bun run typecheck",
    "doctor": "bun run doctor:pi-mom",
    "dev:pi-mom": "cd apps/pi-mom && bun run start",
    "doctor:pi-mom": "cd apps/pi-mom && bun run doctor",
    "check:pi-mom": "cd apps/pi-mom && bun run check",
    "typecheck": "tsc --noEmit",
    "validate:skills": "bun scripts/validate-skills.mjs",
    "validate:agents": "bun scripts/validate-agents.mjs",
    "agent:new": "bun scripts/scaffold-agent.mjs",
    "secret-scan": "bash scripts/secret-scan.sh",
    "install:pi": "bash scripts/install-local.sh"
  },
  "pi": {
    "extensions": [
      "./extensions/env-guard.ts",
      "./extensions/git-checkpoint.ts",
      "./extensions/linear-mcp-guard.ts",
      "./extensions/permission-gate.ts",
      "./extensions/slack-mcp-guard.ts",
      "./packages/pi-ext-covent-aws/src/index.ts"
    ],
    "skills": ["./skills"],
    "agents": ["./.pi/agents", "./agents"],
    "prompts": ["./prompts"]
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^22.15.3",
    "typebox": "latest",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22"
  }
}
