{
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "strict": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun", "node"],
    "lib": ["ES2022"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*"]
}
