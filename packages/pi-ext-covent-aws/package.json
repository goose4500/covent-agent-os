{
  "name": "pi-ext-covent-aws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pi extension exposing scoped AWS primitives (S3, SSM, SQS, CloudWatch Logs) for the Covent Pi workbench. Lane-gated via COVENT_LANE env var: bridge | operator. No credentials in code — relies on EC2 instance profile / AWS_PROFILE.",
  "keywords": ["pi-package", "pi-extension", "aws", "covent"],
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5.7"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  }
}
