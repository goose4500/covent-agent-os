# Placeholders — set real values in Railway Variables, never in git.

# Shared secret with covent-pi-mom. Required.
# Generated locally with: openssl rand -hex 32
PREVIEW_SHARED_SECRET=

# Public base URL the service is served at. Used to build the URL returned
# from PUT /upload. Required so the bot can post a working link to Slack.
PREVIEW_BASE_PUBLIC=https://covent-pi-preview.up.railway.app

# Days before a preview is auto-deleted. Lazy on read + 6h background sweep.
PREVIEW_TTL_DAYS=7

# Directory where bundles are stored. On Railway this is the Volume mount.
PREVIEW_DIR=/data/previews

# HTTP port Bun.serve listens on. Railway routes the public domain here.
PORT=8080
