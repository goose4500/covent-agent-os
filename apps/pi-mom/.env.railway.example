# Railway variable template for covent-pi-mom.
# Set real secret values in Railway Variables, never in git.

# Required Slack Socket Mode credentials
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
EXPECTED_SLACK_BOT_USER=covent_pi

# Required channel guard for POC
SLACK_ALLOWED_CHANNEL_ID=C0B05VBGJKF
SLACK_TEST_CHANNEL_NAME=idea-specs

# Pi runtime mode
PI_MOM_MODE=pi
PI_COMMAND=pi
PI_EXTRA_ARGS=--model openai/gpt-4o-mini
PI_MOM_STREAMING=true
PI_MOM_TRACE=true
PI_MOM_ALLOW_PI_TOOLS=false
PI_TIMEOUT_MS=180000
PI_OUTPUT_IDLE_MS=2000
MAX_SLACK_TEXT=38000

# AI provider key for Pi. Use whichever provider/model PI_EXTRA_ARGS targets.
OPENAI_API_KEY=sk-...

# Optional Linear issue creation route.
# Required only for `@Covent Pi create Linear issue` / `linear:`.
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
LINEAR_DEFAULT_STATE_NAME=Backlog

# Linear webhook receiver (W-B). The receiver listens on LINEAR_WEBHOOK_PORT
# only when LINEAR_WEBHOOK_SIGNING_SECRET is set. Expose the port publicly so
# Linear can reach /webhooks/linear. See docs/runbooks/linear-webhook-setup.md.
LINEAR_WEBHOOK_SIGNING_SECRET=whsec_replace_me
LINEAR_WEBHOOK_SIGNING_SECRET_PREVIOUS=
LINEAR_WEBHOOK_PORT=3001
LINEAR_WEBHOOK_REQUIRED=false

# Optional image route. Keep off for first Railway POC unless intentionally testing it.
PI_MOM_IMAGE_ROUTE_ENABLED=false
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_OUTPUT_FORMAT=png
PI_MOM_IMAGE_OUTPUT_DIR=/tmp/covent-pi-mom-images
PI_MOM_IMAGE_MAX_INPUTS=4
PI_MOM_IMAGE_MAX_BYTES=20971520
