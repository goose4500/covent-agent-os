# Railway variable template for covent-pi-mom.
# Set real secret values in Railway Variables, never in git.

# Required Slack Socket Mode credentials
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
EXPECTED_SLACK_BOT_USER=covent_pi

SLACK_TEST_CHANNEL_NAME=idea-specs

# Pi runtime mode — parent Pi runs are embedded in-process via @earendil-works/pi-coding-agent.
# All registered Pi tools/skills/app extensions are default-on for Pi-backed routes.
# The team/subagent workflow launches child `pi` CLI runs, so the deployment image
# must also have `pi` on PATH.
PI_MOM_MODE=pi
PI_MOM_MODEL=openai-codex/gpt-5.5
PI_MOM_THINKING_LEVEL=high
# Slack streaming is always on via lib/slack-sink.mjs (Stage 5). The legacy
# PI_MOM_STREAMING knob was removed.
PI_MOM_TRACE=true
# No colon-prefixed route layer. Every @-mention is handed to the agent as
# plain text; the agent picks tools and skills dynamically. The runner
# activates every registered SDK tool for normal Slack Pi turns. Stage 6
# (slack-ui-context, slack-canvas, bridge tools) is wired automatically.
PI_TIMEOUT_MS=180000
# Skip the SDK's auto `npm install -g` of user-scope packages at session creation.
# Runner sets this internally if unset; listed here for Railway visibility.
PI_OFFLINE=1
# The runner loads app-pinned pi-subagents and pi-web-access explicitly; ambient
# extension auto-discovery and SDK auto-install remain off.
# Optional web providers. Keep values in Railway Variables only.
EXA_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# Keep browser-cookie Gemini Web off by default in Railway.
PI_ALLOW_BROWSER_COOKIES=0
MAX_SLACK_TEXT=38000

# Provider API key for Pi. Match this to PI_MOM_MODEL's provider (e.g. openai-codex → OPENAI_API_KEY).
OPENAI_API_KEY=sk-...

# pi-mcp-adapter is loaded inline by pi-sdk-runner.mjs. Set this to the
# base64 of your mcp.json (`base64 -w0 < mcp.json`) and the runner will
# seed it to `${PI_AGENT_DIR}/mcp.json` on cold boot only when the file
# is missing — Pi persists OAuth tokens and directTools overrides back
# into that file, so we never overwrite an existing one. Rotate by
# deleting the file on the volume and redeploying.
PI_MCP_JSON_B64=
# Optional built-in Slack MCP preset. When enabled and no mcp.json exists, the
# runner seeds a lazy Slack MCP server that reads the bearer token from the env
# var named by SLACK_MCP_BEARER_TOKEN_ENV. Do not paste token values into Slack
# or git; set them only in Railway Variables/secret manager.
SLACK_MCP_ENABLED=0
SLACK_MCP_BEARER_TOKEN_ENV=SLACK_MCP_USER_TOKEN
SLACK_MCP_USER_TOKEN=
SLACK_MCP_DIRECT_TOOLS=0

# Optional Linear issue creation route.
# Required only for `@Covent Pi create Linear issue` / `linear:`.
# LINEAR_API_KEY is org-wide; the model picks a team per request via
# `team_id` resolved at runtime through linear_list_teams. The vars below
# only act as DEFAULTS for when the model omits team_id/project_id.
# Reference team UUIDs (verified 2026-05-15):
#   FE  Frontend Engineering    c9c8376e-7fd3-4921-9996-8c98fc2274f2
#   BE  Backend Engineering     73c38bb9-46d4-45c6-a970-6800214a15a2
#   RND Research and Development c0c3d247-e279-4928-b27c-ce1d32c33dce
#   HIS Historical Data         a932029a-3599-4324-81e4-88244a5e9cbf
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
LINEAR_STATE_ID=adfdb6e9-b118-4d65-ada3-ad11087b7dab

# Image generation was removed; no PI_MOM_IMAGE_* or OPENAI_IMAGE_* vars are
# consumed by the bot. OPENAI_API_KEY above is still required for Pi when
# PI_MOM_MODEL targets an OpenAI provider.
