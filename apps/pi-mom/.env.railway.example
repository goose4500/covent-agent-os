# Railway variable template for covent-pi-mom.
# Set real secret values in Railway Variables, never in git.

# Required Slack Socket Mode credentials
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
EXPECTED_SLACK_BOT_USER=covent_pi

# Required channel guard for POC
SLACK_ALLOWED_CHANNEL_ID=C0B05VBGJKF
SLACK_TEST_CHANNEL_NAME=idea-specs

# Pi runtime mode. Pi runs embedded as the @earendil-works/pi-coding-agent SDK;
# there is no subprocess and no `--no-tools` flag — per-Action tool gating is
# driven by control-plane/registry.yaml.
PI_MOM_MODE=pi
PI_MOM_TRACE=true

# Per-thread session persistence (threadTs → on-disk Pi session file).
PI_MOM_RUN_STATE_PATH=/tmp/covent-pi-mom-runs.json

# AI provider key for the embedded Pi SDK. Provide whichever provider your
# selected model needs (OpenAI here, ANTHROPIC_API_KEY for Anthropic models).
OPENAI_API_KEY=sk-...

# Optional Linear issue creation route.
# Required only for `@Covent Pi create Linear issue` / `linear:`.
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
LINEAR_STATE_ID=adfdb6e9-b118-4d65-ada3-ad11087b7dab
