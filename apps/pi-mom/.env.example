# Copy to an untracked local env file or load from 1Password/op in a wrapper.
# Never paste real tokens into Pi chat, Slack, git, screenshots, or logs.

# Slack Bot User OAuth Token, from OAuth & Permissions. Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token, from Basic Information > App-Level Tokens.
# Must include connections:write. Starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Optional: restrict replies to your private test channel after you know its ID.
# First run can leave this blank; mention the bot in #idea-specs and the console logs the channel ID.
SLACK_ALLOWED_CHANNEL_ID=
SLACK_TEST_CHANNEL_NAME=idea-specs

# Pi SDK config. Pi is now embedded in-process via @earendil-works/pi-coding-agent;
# no `pi` binary is spawned. Match PI_MOM_MODEL's provider with the API key you set below.
# Format: <provider>/<modelId>.
PI_MOM_MODEL=openai-codex/gpt-5.5
PI_MOM_THINKING_LEVEL=high # off | minimal | low | medium | high | xhigh
# Hard wall-clock timeout per Pi run (ms). agent_end is authoritative; no idle timeout.
PI_TIMEOUT_MS=180000
# Skip the SDK's auto `npm install -g` of user-scope packages from ~/.pi/agent/settings.json.
# The bot runs `noTools: "all"`; it does not use pi-web-access / pi-subagents / etc.
# The runner sets this internally if unset, but it's listed here for visibility.
PI_OFFLINE=1
PI_MOM_MODE=echo # echo | pi
# Slack streaming is always on via lib/slack-sink.mjs (Stage 5). The legacy
# PI_MOM_STREAMING, PI_MOM_STREAM_APPEND_CHARS, and PI_MOM_STREAM_BUFFER_CHARS
# env vars were removed — slack-sink batches text deltas every 200 ms and
# emits zero-width-space heartbeats every 25 s to keep Slack's stream
# session alive past long thinking-level=high runs.
# Per-route Pi tool gating is configured in apps/pi-mom/control-plane/registry.yaml
# under the `routes:` block (each route declares `tools: [...]`). The legacy
# PI_MOM_ALLOW_PI_TOOLS env flag was removed in Stage 4 of the foundation
# rebuild — empty tools array = no Pi tools active; non-empty array narrows
# active tools via SDK setActiveToolsByName.
# Stage 6: when a Pi extension calls ctx.ui.{confirm,select,input,notify} the
# bridge translates each into Slack interactive blocks (and a modal for
# `input`). No env vars to configure — the bot just needs `chat:write` and
# the `actions` / `views` permissions in its Slack manifest.

# Optional Agent Run Card route for `@Covent Pi agent:`.
# `PI_MOM_AGENT_ROUTE_ENABLED=false` disables new cards and Start/Cancel button execution.
PI_MOM_AGENT_ROUTE_ENABLED=true
PI_MOM_AGENT_RUNNER=fake # fake | repo-health
PI_MOM_RUN_STATE_PATH=$HOME/.pi/agent/pi-mom/runs.json
PI_MOM_AGENT_CANVAS_ENABLED=true
PI_MOM_AGENT_MAX_CONCURRENT=1
PI_MOM_REPO_HEALTH_WORKDIR=/home/jfloyd/covent-agent-os

# Optional Linear issue creation route for `@Covent Pi create Linear issue` in PI_MOM_MODE=pi.
# Keep real keys in a secret manager/local env only; never commit them.
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
# LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
# LINEAR_STATE_ID=adfdb6e9-b118-4d65-ada3-ad11087b7dab

# OpenAI API key. Required for both the `image:` route AND for Pi when PI_MOM_MODEL targets an OpenAI provider.
# Keep real keys in a secret manager/local env only; never commit them.
# OPENAI_API_KEY=sk-your-openai-key
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_OUTPUT_FORMAT=png
PI_MOM_IMAGE_ROUTE_ENABLED=true
PI_MOM_IMAGE_OUTPUT_DIR=$HOME/.pi/agent/generated-images/slack
PI_MOM_IMAGE_MAX_INPUTS=4
PI_MOM_IMAGE_MAX_BYTES=20971520
# OPENAI_IMAGE_MODEL_FALLBACKS=gpt-image-1.5,gpt-image-1
