# Copy to an untracked local env file or load from 1Password/op in a wrapper.
# Never paste real tokens into Pi chat, Slack, git, screenshots, or logs.

# Slack Bot User OAuth Token, from OAuth & Permissions. Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token, from Basic Information > App-Level Tokens.
# Must include connections:write. Starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Optional: restrict replies to your private test channel after you know its ID.
# First run can leave this blank; mention the bot in #idea-specs and the console logs the channel ID.
SLACK_ALLOWED_CHANNEL_ID=
SLACK_TEST_CHANNEL_NAME=idea-specs

# Optional: point to a specific Pi binary/model.
PI_COMMAND=pi
# Example: PI_EXTRA_ARGS=--model openai-codex/gpt-5.5:high
PI_EXTRA_ARGS=
PI_MOM_MODE=echo # echo | pi
PI_MOM_STREAMING=true

# Optional Linear issue creation route for `@Covent Pi create Linear issue` in PI_MOM_MODE=pi.
# Keep real keys in a secret manager/local env only; never commit them.
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
# LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
# LINEAR_STATE_ID=adfdb6e9-b118-4d65-ada3-ad11087b7dab

# Optional OpenAI image route for `@Covent Pi image:` in PI_MOM_MODE=pi.
# Keep real keys in a secret manager/local env only; never commit them.
# OPENAI_API_KEY=sk-your-openai-key
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_OUTPUT_FORMAT=png
PI_MOM_IMAGE_ROUTE_ENABLED=true
PI_MOM_IMAGE_OUTPUT_DIR=$HOME/.pi/agent/generated-images/slack
PI_MOM_IMAGE_MAX_INPUTS=4
PI_MOM_IMAGE_MAX_BYTES=20971520
# OPENAI_IMAGE_MODEL_FALLBACKS=gpt-image-1.5,gpt-image-1

# Insights Auto-Analyzer route. OFF by default; flip on per-channel after rollout.
# Listens to top-level messages in INSIGHTS_CHANNEL_ID, extracts Twitter/X, YouTube,
# and Spotify URLs, fetches transcripts via Apify, runs first-principles analysis
# through the existing Pi subprocess, and replies in-thread.
INSIGHTS_FEATURE_ENABLED=false
# Slack channel ID for #insights (e.g. C09ABCDEF12). Independent of SLACK_ALLOWED_CHANNEL_ID.
INSIGHTS_CHANNEL_ID=
# Apify API token (https://console.apify.com/account/integrations).
# APIFY_API_TOKEN=apify_api_xxx
# Apify actor slugs (use ~ between user and actor). Defaults are sensible starting points.
INSIGHTS_APIFY_ACTOR_TWITTER=apidojo~twitter-scraper-lite
INSIGHTS_APIFY_ACTOR_YOUTUBE=pintostudio~youtube-transcript-scraper
INSIGHTS_APIFY_ACTOR_SPOTIFY=pintostudio~spotify-scraper
# Truncation cap on transcript fed to Pi (chars).
INSIGHTS_TRANSCRIPT_MAX_CHARS=60000
# Per-link Apify timeout in ms.
INSIGHTS_PER_LINK_TIMEOUT_MS=90000
# In-memory dedupe TTL (ms). Same URL within this window is silently skipped.
INSIGHTS_DEDUPE_TTL_MS=3600000
# Pi extra args appended only for the insights call (e.g. select Sonnet 4.6).
# INSIGHTS_PI_EXTRA_ARGS=--model anthropic/claude-sonnet-4-6
# Set to true to skip Pi and post fetched metadata + transcript head — useful for
# verifying Apify in production without spending model tokens.
INSIGHTS_DRY_RUN=false

# Phase 2 (not implemented in v1) — reserved env names for the Notion archive:
# INSIGHTS_NOTION_ENABLED=false
# NOTION_API_TOKEN=
# INSIGHTS_NOTION_DATABASE_ID=
