# Copy to an untracked local env file or load from 1Password/op in a wrapper.
# Never paste real tokens into Pi chat, Slack, git, screenshots, or logs.

# Slack Bot User OAuth Token, from OAuth & Permissions. Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App-Level Token, from Basic Information > App-Level Tokens.
# Must include connections:write. Starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-level-token

# Slack App Configuration Token for `apps.manifest.update`. Rotates ~12h, so
# never paste this into env files; supply it as a CI secret (SLACK_APP_CONFIG_TOKEN)
# instead. Only the slack-manifest-push GitHub Action needs it.
# Get one at https://api.slack.com/apps → "Your App Configuration Tokens".
# SLACK_APP_CONFIG_TOKEN=xoxe-...
# Slack App ID the manifest targets (also required by the manifest push workflow).
# SLACK_APP_ID=A0XXXXXX

# Optional: restrict replies to approved channel IDs after you know them.
# Use comma-separated IDs for multiple channels, or set SLACK_ALLOWED_CHANNEL_IDS.
# First run can leave this blank; mention the bot in #idea-specs and the console logs the channel ID.
SLACK_ALLOWED_CHANNEL_ID=
# SLACK_ALLOWED_CHANNEL_IDS=C0B05VBGJKF,C0B30N60HGW
SLACK_TEST_CHANNEL_NAME=idea-specs

# Pi SDK config. Parent Pi runs are embedded in-process via @earendil-works/pi-coding-agent.
# All registered Pi tools/skills/app extensions are default-on for Pi-backed routes.
# The team/subagent workflow launches child `pi` CLI runs, so deployment/runtime
# images must also have `pi` on PATH.
# Match PI_MOM_MODEL's provider with the API key you set below.
# Format: <provider>/<modelId>.
PI_MOM_MODEL=openai-codex/gpt-5.5
PI_MOM_THINKING_LEVEL=high # off | minimal | low | medium | high | xhigh
# Hard wall-clock timeout per Pi run (ms). agent_end is authoritative; no idle timeout.
PI_TIMEOUT_MS=180000
# Skip the SDK's auto `npm install -g` of user-scope packages from ~/.pi/agent/settings.json.
# Approved packages are loaded from app dependencies through an explicit resource loader;
# ambient user-scope package installs stay off. The runner sets this internally if unset,
# but it's listed here for visibility.
PI_OFFLINE=1
# Optional web providers for default-on pi-web-access tools (values hidden in real env/secret manager):
EXA_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
# Keep off unless an operator explicitly opts into browser-cookie Gemini Web locally.
PI_ALLOW_BROWSER_COOKIES=0
PI_MOM_MODE=echo # echo | pi
# Slack streaming is always on via lib/slack-sink.mjs (Stage 5). The legacy
# PI_MOM_STREAMING, PI_MOM_STREAM_APPEND_CHARS, and PI_MOM_STREAM_BUFFER_CHARS
# env vars were removed — slack-sink batches text deltas every 200 ms and
# emits zero-width-space heartbeats every 25 s to keep Slack's stream
# session alive past long thinking-level=high runs.
# The bridge no longer routes user messages through fixed colon-prefixed
# workflows. Every @-mention is handed to the agent as plain text; the agent
# picks tools (slack_canvas_start, linear_create_issue, bridge_help, ...) and
# skills (slack-spec-draft, slack-thread-summary, ...) dynamically. Only the
# bare keywords `help` / `status` are short-circuited bridge-side. The runner
# activates every registered SDK tool for normal Slack Pi turns.
# Stage 6: when a Pi extension calls ctx.ui.{confirm,select,input,notify} the
# bridge translates each into Slack interactive blocks (and a modal for
# `input`). No env vars to configure — the bot just needs `chat:write` and
# the `actions` / `views` permissions in its Slack manifest.

# Linear is now driven by the `linear_create_issue` Pi custom tool
# (extensions/linear-tools.ts), registered automatically by pi-sdk-runner.
# The model invokes the tool directly; the bridge no longer scrapes streamed
# output to create issues. The legacy post-stream GraphQL call and the
# thread-scan idempotency module (lib/linear-idempotency.mjs) were deleted.
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=c9c8376e-7fd3-4921-9996-8c98fc2274f2
# LINEAR_PROJECT_ID=ba9682e2-c14e-4208-98a2-a89f3fb285b8
# LINEAR_STATE_ID=adfdb6e9-b118-4d65-ada3-ad11087b7dab

# OpenAI API key. Required for Pi when PI_MOM_MODEL targets an OpenAI provider.
# Image generation was removed; keep real keys in a secret manager/local env only.
# OPENAI_API_KEY=sk-your-openai-key

# pi-mcp-adapter MCP server config. The adapter (loaded inline by
# pi-sdk-runner.mjs) reads, in precedence order:
#   1. ~/.config/mcp/mcp.json   (user-global shared)
#   2. ${PI_AGENT_DIR}/mcp.json (Pi global override — Railway target)
#   3. .mcp.json                (project shared)
#   4. .pi/mcp.json             (Pi project override; .pi/ is gitignored)
# Locally, drop a .mcp.json next to where you launch the bot OR set the
# env var below to a base64-encoded mcp.json that the runner will seed
# into ${PI_AGENT_DIR}/mcp.json on cold boot if the file is missing.
# PI_MCP_JSON_B64=
# Optional built-in Slack MCP preset. When enabled and no mcp.json exists, the
# runner seeds a lazy Slack MCP server using bearerTokenEnv below; never put the
# token value in this file.
# SLACK_MCP_ENABLED=0
# SLACK_MCP_BEARER_TOKEN_ENV=SLACK_MCP_USER_TOKEN
# SLACK_MCP_USER_TOKEN=
# SLACK_MCP_DIRECT_TOOLS=0
# Optional override: skip adapter file lookup and read directly from a path.
# MCP_CONFIG_PATH=/absolute/path/to/mcp.json
# Optional: comma-separated MCP tool names to register as top-level "direct
# tools" instead of going through the `mcp` proxy. "__none__" disables all
# direct tools regardless of the per-server `directTools` config.
# MCP_DIRECT_TOOLS=
