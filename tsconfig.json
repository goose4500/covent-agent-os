{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "extensions/**/*.ts",
    "packages/**/*.ts",
    "lib/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "apps/pi-mom/node_modules"
  ]
}
